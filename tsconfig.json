{
  "compilerOptions": {
    "target":          "ES2022",
    "module":          "commonjs",
    "lib":             ["ES2022", "DOM"],
    "strict":          true,
    "esModuleInterop": true,
    "skipLibCheck":    true,
    "resolveJsonModule": true,
    "outDir":          "dist",
    "rootDir":         ".",
    "baseUrl":         ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*", "playwright.config.ts", "global-setup.ts"],
  "exclude": ["node_modules", "dist", "playwright-report"]
}
