# ─── Sands of Fortune: Hold & Win — Environment Variables ──────────────────────
# Copy this file to .env and fill in your values. Never commit .env to git.

# Full game URL including JWT token for the target environment.
# The gstoken is refreshed automatically by global-setup.ts using USERNAME/PASSWORD.
# Engine parameter: et=tr  (Sands of Fortune uses the "tr" engine)
GAME_URL=https://gs.avocadospins.com/demo?gstoken=YOUR_JWT_HERE&mode=demo&locale=en&et=tr

# Same URL but with debug=true appended — used by edge-case and bonus tests
# to activate the stub.js trigger system for deterministic outcomes.
GAME_URL_DEBUG=https://gs.avocadospins.com/demo?gstoken=YOUR_JWT_HERE&mode=demo&locale=en&et=tr&debug=true

# Base origin — used by playwright.config.ts for relative URL resolution
BASE_URL=https://gs.avocadospins.com

# Launcher credentials for auto-refreshing the gstoken before each test run.
# global-setup.ts uses these to call the mock-operator API and write a fresh URL.
USERNAME=toucanroyale
PASSWORD=VjtQGZv1pLxx

# ─── Endurance / RNG test settings ──────────────────────────────────────────────
# How many spins to run in the endurance test (08-endurance.spec.ts)
ENDURANCE_SPIN_COUNT=500

# How many spins for the RNG distribution test (09-rng-stats.spec.ts)
RNG_SPIN_COUNT=1000

# RTP target % and acceptable deviation (e.g. 0.05 = ±5pp tolerance)
RTP_TARGET=96.0
RTP_TOLERANCE=15.0
